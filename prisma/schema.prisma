generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ProviderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MealAvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
}

enum OrderStatus {
  PLACED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role
  status    UserStatus @default(ACTIVE)
  phone     String?
  avatar    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  providerProfile ProviderProfile?
  cartItems       CartItem[]
  customerOrders  Order[]          @relation("CustomerOrders")
  reviews         Review[]
  favorites       Favorite[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model ProviderProfile {
  id                 String                 @id @default(uuid())
  userId             String                 @unique
  businessName       String
  slug               String                 @unique
  logo               String?
  banner             String?
  description        String?
  address            String
  city               String?
  cuisineSpecialties String[]
  approvalStatus     ProviderApprovalStatus @default(PENDING)
  isOpen             Boolean                @default(true)
  averageRating      Float                  @default(0)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals  Meal[]
  orders Order[]

  @@index([approvalStatus])
  @@index([businessName])
  @@map("provider_profiles")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meals Meal[]

  @@map("categories")
}

model Meal {
  id                 String                 @id @default(uuid())
  providerProfileId  String
  categoryId         String
  title              String
  slug               String                 @unique
  shortDescription   String?
  description        String
  price              Decimal                @db.Decimal(10, 2)
  image              String?
  availabilityStatus MealAvailabilityStatus @default(AVAILABLE)
  stockQuantity      Int?
  spiceLevel         String?
  dietaryTags        String[]
  preparationTime    Int?
  featured           Boolean                @default(false)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Restrict)
  category        Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  cartItems       CartItem[]
  orderItems      OrderItem[]
  reviews         Review[]
  favorites       Favorite[]

  @@index([providerProfileId])
  @@index([categoryId])
  @@index([availabilityStatus])
  @@index([featured])
  @@index([price])
  @@map("meals")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  mealId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@unique([userId, mealId])
  @@index([userId])
  @@map("cart_items")
}

model Order {
  id                String        @id @default(uuid())
  customerId        String
  providerProfileId String
  totalAmount       Decimal       @db.Decimal(10, 2)
  deliveryAddress   String
  phone             String
  note              String?
  paymentMethod     PaymentMethod @default(COD)
  status            OrderStatus   @default(PLACED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customer        User            @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)
  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Restrict)
  orderItems      OrderItem[]

  @@index([customerId])
  @@index([providerProfileId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  mealId     String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  meal  Meal  @relation(fields: [mealId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Review {
  id         String       @id @default(uuid())
  customerId String
  mealId     String
  rating     Int
  comment    String?
  status     ReviewStatus @default(PUBLISHED)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  customer User @relation(fields: [customerId], references: [id], onDelete: Cascade)
  meal     Meal @relation(fields: [mealId], references: [id], onDelete: Restrict)

  @@unique([customerId, mealId])
  @@index([mealId])
  @@index([customerId])
  @@map("reviews")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  mealId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@unique([userId, mealId])
  @@map("favorites")
}
